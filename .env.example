# Dashboard env overrides. Copy to `.env.local` and fill in.
# All Vite env vars surfaced to the SPA must be prefixed with VITE_.

# Where to find the backend API. Leave UNSET in local dev so the Vite dev-server
# proxy on /api/* forwards to http://127.0.0.1:3099 (configured in vite.config.ts).
# On Vercel (or any deployment that bundles `npm run build`), set this to the full
# URL of the deployed backend, including the /api/v1 suffix.
#
# Example for the current Render deployment:
#   VITE_API_BASE_URL=https://trendzo-backend-86wn.onrender.com/api/v1
VITE_API_BASE_URL=

# --- MSG91 phone-OTP login widget (PUBLIC values — safe to expose in the client) ---
# Retailer OTP web widget id + auth token. Optional: the app falls back to the built-in
# retailer widget when unset. Override to point at a different MSG91 widget/account.
# (The SECRET account authkey lives only in the backend, never here.)
VITE_MSG91_WIDGET_ID=
VITE_MSG91_TOKEN_AUTH=
